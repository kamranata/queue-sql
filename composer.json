{
    "name": "kamranata/queue-sql",
    "description": "Queue any Laravel write query (delete/update/insert) across parallel batched jobs.",
    "keywords": [
        "laravel",
        "php",
        "queue",
        "batch",
        "bulk",
        "mass-delete",
        "mass-update",
        "bulk-insert",
        "eloquent",
        "database",
        "jobs"
    ],
    "homepage": "https://github.com/kamranata/queue-sql",
    "license": "MIT",
    "authors": [
        {
            "name": "Kamran Atayev",
            "homepage": "https://github.com/kamranata"
        }
    ],
    "support": {
        "issues": "https://github.com/kamranata/queue-sql/issues",
        "source": "https://github.com/kamranata/queue-sql"
    },
    "require": {
        "php": "^8.1",
        "illuminate/database": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/bus": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": { "psr-4": { "QueueSql\\": "src/" } },
    "autoload-dev": { "psr-4": { "QueueSql\\Tests\\": "tests/" } },
    "extra": {
        "laravel": { "providers": ["QueueSql\\QueueSqlServiceProvider"] }
    },
    "scripts": { "test": "phpunit" },
    "minimum-stability": "dev",
    "prefer-stable": true
}
